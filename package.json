{
  "name": "manpowerhub",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "storybook:ui": "pnpm --filter @manpowerhub/ui storybook",
    "storybook:blocks": "pnpm --filter @manpowerhub/blocks storybook",
    "lint": "eslint .",
    "test": "pnpm -r test",
    "changeset": "changeset",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^8.2.0",
    "@storybook/addon-themes": "^8.2.0",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.2.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "postcss-import": "^16.1.1",
    "prettier": "^3.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^8.6.18",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "packageManager": "pnpm@9.7.0",
  "pnpm": {
    "patchedDependencies": {
      "nextra-theme-docs@4.6.1": "patches/nextra-theme-docs@4.6.1.patch"
    }
  }
}
